<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="80dp"
    android:layout_marginVertical="50dp"
    android:clipChildren="true">

    <!-- Action buttons revealed on swipe (behind the content) -->
    <LinearLayout
        android:id="@+id/swipe_actions"
        android:layout_width="160dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:background="@drawable/swipe_actions_background">

        <Button
            android:id="@+id/btn_edit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Éditer"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#5C6BC0"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Supp."
            android:backgroundTint="@android:color/transparent"
            android:textColor="#E53935"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Main task card (slides left on swipe) -->
    <LinearLayout
        android:id="@+id/task_item_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/task_item_background"
        android:padding="14dp"
        android:elevation="2dp">

        <!-- Header row: title + indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/task_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Titre de la tâche"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>

            <!-- Chevron indicator (▼ collapsed, ▲ expanded) -->
            <TextView
                android:id="@+id/task_chevron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:paddingStart="8dp"/>

        </LinearLayout>

        <!-- Expandable details with slide animation -->
        <LinearLayout
            android:id="@+id/task_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="10dp">

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/task_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#424242"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/task_date_debut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date début"
                android:textColor="#616161"
                android:textSize="13sp"
                android:drawablePadding="4dp"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/task_date_fin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date fin"
                android:textColor="#616161"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/task_severity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/severity_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"/>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>