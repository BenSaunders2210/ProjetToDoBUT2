<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:clipChildren="true">

    <!-- Action buttons revealed on swipe (behind the content) -->
    <LinearLayout
        android:id="@+id/swipe_actions"
        android:layout_width="160dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_edit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Éditer"
            android:backgroundTint="#90CAF9"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Supp."
            android:backgroundTint="#EF5350"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- Main task card (slides left on swipe) -->
    <LinearLayout
        android:id="@+id/task_item_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/task_item_background"
        android:padding="12dp">

        <TextView
            android:id="@+id/task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Titre de la tâche"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"/>

        <LinearLayout
            android:id="@+id/task_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/task_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@android:color/black"/>

            <TextView
                android:id="@+id/task_date_debut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date début"
                android:textColor="@android:color/black"/>

            <TextView
                android:id="@+id/task_date_fin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date fin"
                android:textColor="@android:color/black"/>

            <TextView
                android:id="@+id/task_severity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sévérité"
                android:textStyle="italic"
                android:textColor="@android:color/black"/>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>